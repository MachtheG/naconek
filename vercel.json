{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    {
      "src": "/(.*\\.(?:css|js|mjs|map|jpg|jpeg|png|gif|svg|webp|avif|ico|bmp|ttf|otf|woff|woff2|eot|txt|xml|json))",
      "dest": "/public/$1"
    },
    {
      "src": "/storage/(.*)",
      "dest": "/public/storage/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}